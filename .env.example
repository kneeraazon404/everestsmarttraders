# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL (used for absolute URLs in metadata, OG images, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Username login domain (username -> username@domain)
NEXT_PUBLIC_ADMIN_LOGIN_DOMAIN=est.com

# Optional: Supabase Storage bucket name (default: "media")
NEXT_PUBLIC_STORAGE_BUCKET=media
